<div class="w-full flex justify-center items-center h-dvh shadow-xl bg-gray-100 dark:bg-gray-950">
    <div class="relative flex flex-col rounded-xl bg-white p-5 dark:bg-gray-900 dark:shadow-gray-950">
        <h4 class="block text-xl font-medium text-slate-800 dark:text-slate-100">Sign Up</h4>
        <form id="signupform" class="mt-8 mb-2 w-80 max-w-5xl sm:w-96" action="signup" method="post">
            <div class="mb-1 flex flex-col gap-6">

                <div class="flex gap-2">
                    <div class="w-full max-w-sm">
                        <label class="block mb-2 text-sm text-slate-600 dark:text-slate-300"> First Name </label>
                        <input type="text" name="firstName" class=" w-full
                        bg-transparent placeholder:text-slate-400 dark:placeholder:text-slate-500 text-slate-700 dark:text-slate-100 text-sm border rounded-md px-3 py-2 border-slate-300 dark:border-gray-700 dark:bg-gray-950 transition duration-300 ease focus:outline-none focus:border-slate-400 dark:focus:border-slate-500
                        hover:border-slate-300 dark:hover:border-slate-500 shadow-sm focus:shadow" placeholder="Shri"
                            id="signUpFieldFirstName" {{#if old.firstName}} value="{{old.firstName}}" {{/if}} />
                    </div>

                    <div class="w-full max-w-sm">
                        <label class="block mb-2 text-sm text-slate-600 dark:text-slate-300"> Last Name </label>
                        <input type="text" name="lastName" class=" w-full
                        bg-transparent placeholder:text-slate-400 dark:placeholder:text-slate-500 text-slate-700 dark:text-slate-100 text-sm border rounded-md px-3 py-2 border-slate-300 dark:border-gray-700 dark:bg-gray-950 transition duration-300 ease focus:outline-none focus:border-slate-400 dark:focus:border-slate-500
                        hover:border-slate-300 dark:hover:border-slate-500 shadow-sm focus:shadow" placeholder="Doe"
                            id="signUpFieldLastName" {{#if old.lastName}} value="{{old.lastName}}" {{/if}} />
                    </div>
                </div>

                <div class="w-full max-w-sm min-w-50">
                    <label class="block mb-2 text-sm text-slate-600 dark:text-slate-300"> Username </label>
                    <input type="text" name="username" class=" w-full
                        bg-transparent placeholder:text-slate-400 dark:placeholder:text-slate-500 text-slate-700 dark:text-slate-100 text-sm border rounded-md px-3 py-2 border-slate-300 dark:border-gray-700 dark:bg-gray-950 transition duration-300 ease focus:outline-none focus:border-slate-400 dark:focus:border-slate-500
                        hover:border-slate-300 dark:hover:border-slate-500 shadow-sm focus:shadow"
                        placeholder="Your Username" id="signUpFieldUsername" {{#if old.username}}
                        value="{{old.username}}" {{/if}} />
                </div>

                <div class="w-full max-w-sm min-w-50">
                    <label class="block mb-2 text-sm text-slate-600 dark:text-slate-300"> Email </label>
                    <input type="email" name="email" class=" w-full
                        bg-transparent placeholder:text-slate-400 dark:placeholder:text-slate-500 text-slate-700 dark:text-slate-100 text-sm border rounded-md px-3 py-2 border-slate-300 dark:border-gray-700 dark:bg-gray-950 transition duration-300 ease focus:outline-none focus:border-slate-400 dark:focus:border-slate-500
                        hover:border-slate-300 dark:hover:border-slate-500 shadow-sm focus:shadow"
                        placeholder="Your Email" id="signUpFieldEmail" {{#if old.email}} value="{{old.email}}"
                        {{/if}} />
                </div>

                <div class="w-full max-w-sm min-w-50">
                    <label class="block mb-2 text-sm text-slate-600 dark:text-slate-300">
                        Password
                    </label>
                    <div class="relative">

                        <input type="password" name="password"
                            class="w-full bg-transparent placeholder:text-slate-400 dark:placeholder:text-slate-500 text-slate-700 dark:text-slate-100 text-sm border border-slate-300 dark:border-gray-700 dark:bg-gray-950 rounded-md px-3 py-2 transition duration-300 ease focus:outline-none focus:border-slate-400 dark:focus:border-slate-500 hover:border-slate-300 dark:hover:border-slate-500 shadow-sm focus:shadow"
                            placeholder="Your Password" id="signUpFieldPassword" />
                        <button id="showSignupPasswordBtn"
                            class="text-sm absolute font-mono right-2 top-1.5 text-slate-600 dark:text-slate-200 cursor-pointer bg-slate-100 dark:bg-gray-800 px-2 py-0.5 rounded-md">show</button>
                    </div>
                </div>

                <div class="w-full max-w-sm min-w-50">
                    <label class="block mb-2 text-sm text-slate-600 dark:text-slate-300">
                        Confirm Password
                    </label>
                    <input type="password" name="confirmPassword"
                        class="w-full bg-transparent placeholder:text-slate-400 dark:placeholder:text-slate-500 text-slate-700 dark:text-slate-100 text-sm border border-slate-300 dark:border-gray-700 dark:bg-gray-950 rounded-md px-3 py-2 transition duration-300 ease focus:outline-none focus:border-slate-400 dark:focus:border-slate-500 hover:border-slate-300 dark:hover:border-slate-500 shadow-sm focus:shadow"
                        placeholder="Confirm Password" id="signUpFieldConfirmPassword" />
                </div>
            </div>

            <button id="signUpBtnSubmit"
                class="mt-6 w-full rounded-md bg-slate-800 py-2 px-4 border border-transparent text-center text-sm text-white transition-all shadow-md hover:shadow-lg focus:bg-slate-700 focus:shadow-none active:bg-slate-700 hover:bg-slate-700 active:shadow-none disabled:pointer-events-none disabled:opacity-50 disabled:shadow-none cursor-pointer"
                type="submit">
                Sign Up
            </button>
            <p class="flex justify-center mt-6 text-sm text-slate-600 dark:text-slate-300">
                Already have an account?
                <a href="/login" class="ml-1 text-sm font-semibold text-slate-700 dark:text-slate-100 underline">
                    Log in
                </a>
            </p>
        </form>
    </div>
</div>