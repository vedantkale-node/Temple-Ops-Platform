<title>{{title}}</title>

<div id="logs-container" class="max-w-full mx-auto px-4 sm:px-6">

    <div class="mt-3 sm:mt-8 flex items-start gap-4">
        <span
            class="material-symbols-outlined shrink-0 leading-none text-blue-700 bg-blue-100 dark:bg-blue-950 dark:text-blue-300 p-3 rounded-xl"
            style="font-size: 1.6rem;">
            text_snippet
        </span>
        <div class="min-w-0">
            <p class="text-2xl sm:text-3xl font-semibold tracking-tight text-slate-900 dark:text-slate-100">Logs</p>
            <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400 mt-0.5">Audit logs for entire application
            </p>
        </div>
    </div>


    <div
        class="mt-6 bg-white dark:bg-gray-900 rounded-2xl border border-slate-200 dark:border-gray-800 divide-y divide-slate-100 dark:divide-gray-800 overflow-hidden">

        {{#each logs}}
        <div class="log-row px-4 sm:px-5 py-4 hover:bg-slate-50 dark:hover:bg-gray-800/40 transition-colors">


            <div class="flex flex-wrap items-baseline gap-x-1.5 gap-y-1">
                <span class="material-symbols-outlined text-slate-600 dark:text-slate-400 mr-0.5"
                    style="font-size: 18px;">history</span>
                <span class="text-sm font-medium text-slate-600 dark:text-slate-400">{{this.role}}</span>
                <span class="text-sm font-semibold text-blue-700 dark:text-blue-300">{{this.action}}</span>
                <span class="text-sm text-slate-600 dark:text-slate-400">on</span>
                <span class="text-sm font-semibold text-purple-700 dark:text-purple-300">{{this.resource}}</span>
            </div>


            <div class="mt-2 flex flex-col lg:flex-row lg:items-center gap-2 lg:gap-4 pl-6">

                <div
                    class="flex items-center gap-1.5 lg:w-40 shrink-0 text-xs font-mono text-slate-600 dark:text-slate-400">
                    <span class="material-symbols-outlined shrink-0" style="font-size: 14px;">schedule</span>
                    <span class="wrap-break-word">{{formatDate this.createdAt}}</span>
                </div>

                <p class="log-request flex items-center gap-2 text-xs font-mono flex-1 min-w-0 break-all">
                    <span
                        class="log-method shrink-0 font-bold uppercase tracking-wide px-2 py-0.5 rounded text-white bg-slate-500 dark:bg-slate-600"
                        data-method="{{this.method}}">
                        {{this.method}}
                    </span>
                    <span class="text-slate-600 dark:text-slate-400 break-all">{{this.url}}</span>
                </p>

                <div
                    class="flex items-center gap-1.5 lg:w-32 shrink-0 text-xs font-mono text-slate-600 dark:text-slate-400 lg:justify-end">
                    <span class="material-symbols-outlined shrink-0" style="font-size: 14px;">desktop_windows</span>
                    <span class="break-all">{{this.ip}}</span>
                </div>
            </div>

            <!-- Meta: resourceId / userId -->
            <div class="mt-2 pl-6 flex flex-wrap gap-x-4 gap-y-1 text-xs text-slate-600 dark:text-slate-400">
                <span class="flex items-center gap-1">
                    ResourceId:
                    <code class="font-mono text-slate-600 dark:text-slate-400 break-all">
                        {{#if this.resourceId}}{{this.resourceId}}{{else}}null{{/if}}
                    </code>
                </span>
                <span class="flex items-center gap-1">
                    UserId:
                    <code class="font-mono text-slate-600 dark:text-slate-400 break-all">
                        {{#if this.userId}}{{this.userId}}{{else}}null{{/if}}
                    </code>
                </span>
            </div>

        </div>
        {{/each}}

    </div>

    <div class="flex justify-center items-center gap-2 mt-6 flex-wrap">

        <button hx-get="/logs?page=1" hx-target="#logs-container" hx-swap="outerHTML"
            class="px-4 py-2 rounded-lg shadow-sm cursor-pointer bg-white hover:bg-slate-100 dark:bg-gray-900 dark:text-slate-100 dark:hover:bg-gray-800 flex">
            <span class="material-symbols-outlined">
                keyboard_double_arrow_left
            </span>
        </button>

        <button hx-get="/logs?page={{prevPage}}" hx-target="#logs-container" hx-swap="outerHTML"
            class="px-4 py-2 rounded-lg shadow-sm cursor-pointer bg-white hover:bg-slate-100 dark:bg-gray-900 dark:text-slate-100 dark:hover:bg-gray-800 flex">
            <span class="material-symbols-outlined">
                keyboard_arrow_left
            </span>
        </button>

        <button
            class="px-4 py-2 rounded-lg shadow-sm bg-blue-100 text-blue-600 dark:bg-blue-950 dark:text-blue-200 font-semibold">
            {{page}}
        </button>

        <button hx-get="/logs?page={{nextPage}}" hx-target="#logs-container" hx-swap="outerHTML"
            class="px-4 py-2 rounded-lg shadow-sm cursor-pointer bg-white hover:bg-slate-100 dark:bg-gray-900 dark:text-slate-100 dark:hover:bg-gray-800 flex">
            <span class="material-symbols-outlined">
                keyboard_arrow_right
            </span>
        </button>

        <button hx-get="/logs?page={{totalPages}}" hx-target="#logs-container" hx-swap="outerHTML"
            class="px-4 py-2 rounded-lg shadow-sm cursor-pointer bg-white hover:bg-slate-100 dark:bg-gray-900 dark:text-slate-100 dark:hover:bg-gray-800 flex">
            <span class="material-symbols-outlined">
                keyboard_double_arrow_right
            </span>
        </button>

    </div>

    <p class="text-center text-sm text-gray-600 dark:text-slate-400 my-4">
        Showing page {{page}} of {{totalPages}}
    </p>

</div>

<script>
    (function () {
        var methodStyles = {
            GET: 'bg-sky-600 dark:bg-sky-700',
            POST: 'bg-green-600 dark:bg-green-700',
            PUT: 'bg-amber-600 dark:bg-amber-700',
            PATCH: 'bg-amber-600 dark:bg-amber-700',
            DELETE: 'bg-red-600 dark:bg-red-700'
        };
        document.querySelectorAll('.log-method').forEach(function (el) {
            var method = (el.getAttribute('data-method') || '').trim().toUpperCase();
            var styles = methodStyles[method];
            if (!styles) return;
            el.classList.remove('bg-slate-500', 'dark:bg-slate-600');
            styles.split(' ').forEach(function (cls) { el.classList.add(cls); });
        });
    })();
</script>