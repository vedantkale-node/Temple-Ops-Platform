<title>{{title}}</title>

<div id="logs-container">

    <div class="mt-5 space-y-1 flex items-center gap-5">

        <div>
            <span class="material-symbols-outlined leading-none text-blue-700 bg-blue-200 p-3 rounded-xl"
                style="font-size: 1.8rem;">
                text_snippet
            </span>
        </div>

        <div>
            <p class="text-3xl font-semibold capitalize">Logs</p>
            <p class="text-gray-600 mt-2">Audit logs for entire application</p>
        </div>
    </div>

    <div class="flex flex-col gap-5 mt-5">

        {{#each logs}}

        <div class="bg-white rounded-2xl border border-slate-200 overflow-hidden">

            <div class="flex flex-col xl:flex-row">

                <div
                    class="bg-blue-50 flex xl:flex-col items-center justify-center gap-3 p-5 xl:min-w-52 border-b xl:border-b-0 xl:border-r border-slate-200">

                    <span class="material-symbols-outlined text-blue-700 bg-blue-100 p-3 rounded-xl">
                        nest_clock_farsight_analog
                    </span>

                    <p class="text-center font-semibold text-gray-700 wrap-break-word">
                        {{formatDate this.createdAt}}
                    </p>
                </div>

                <div class="flex-1">

                    <div
                        class="grid grid-cols-1 md:grid-cols-3 xl:grid-cols-6 divide-y md:divide-y-0 md:divide-x divide-slate-200">

                        <div class="p-5 flex flex-col items-center justify-center gap-3 text-gray-500">
                            <p class="flex items-center gap-2">
                                <span class="material-symbols-outlined">
                                    account_circle
                                </span>
                                Role
                            </p>

                            <p class="font-semibold text-blue-600 text-center break-all">
                                {{this.role}}
                            </p>
                        </div>

                        <div class="p-5 flex flex-col items-center justify-center gap-3 text-gray-500">
                            <p class="flex items-center gap-2">
                                <span class="material-symbols-outlined">
                                    shield
                                </span>
                                Action
                            </p>

                            <p class="font-semibold text-blue-600 bg-blue-100 px-3 py-1 rounded-xl break-all">
                                {{this.action}}
                            </p>
                        </div>

                        <div class="p-5 flex flex-col items-center justify-center gap-3 text-gray-500">
                            <p class="flex items-center gap-2">
                                <span class="material-symbols-outlined">
                                    database
                                </span>
                                Resource
                            </p>

                            <p class="font-semibold text-purple-600 bg-purple-100 px-3 py-1 rounded-xl break-all">
                                {{this.resource}}
                            </p>
                        </div>

                        <div class="p-5 flex flex-col items-center justify-center gap-3 text-gray-500">
                            <p class="flex items-center gap-2">
                                <span class="material-symbols-outlined">
                                    code_xml
                                </span>
                                Method
                            </p>

                            <p class="font-semibold text-violet-800 bg-violet-100 px-3 py-1 rounded-xl break-all">
                                {{this.method}}
                            </p>
                        </div>

                        <div class="p-5 flex flex-col items-center justify-center gap-3 text-gray-500">
                            <p class="flex items-center gap-2">
                                <span class="material-symbols-outlined">
                                    globe
                                </span>
                                URL
                            </p>

                            <p class="font-semibold text-blue-600 text-center break-all">
                                {{this.url}}
                            </p>
                        </div>

                        <div class="p-5 flex flex-col items-center justify-center gap-3 text-gray-500">
                            <p class="flex items-center gap-2">
                                <span class="material-symbols-outlined">
                                    desktop_windows
                                </span>
                                IP
                            </p>

                            <p class="font-semibold text-gray-600 bg-gray-100 px-3 py-1 rounded-xl break-all">
                                {{this.ip}}
                            </p>
                        </div>

                    </div>

                    <div class="border-t border-slate-200 flex flex-col sm:flex-row sm:flex-wrap gap-4 p-5 text-sm">

                        <div class="flex flex-wrap items-center gap-2">
                            <p class="font-semibold whitespace-nowrap">
                                ResourceId:
                            </p>

                            <p class="bg-slate-100 rounded-xl py-1 px-3 break-all">
                                {{#if this.resourceId}}
                                {{this.resourceId}}
                                {{else}}
                                null
                                {{/if}}
                            </p>
                        </div>

                        <div class="flex flex-wrap items-center gap-2">
                            <p class="font-semibold whitespace-nowrap">
                                User Id:
                            </p>

                            <p class="bg-slate-100 rounded-xl py-1 px-3 break-all">
                                {{#if this.userId}}
                                {{this.userId}}
                                {{else}}
                                null
                                {{/if}}
                            </p>
                        </div>

                    </div>

                </div>

            </div>

        </div>

        {{/each}}

    </div>
    <div class="flex justify-center items-center gap-2 mt-6 flex-wrap">

        <button hx-get="/logs?page=1" hx-target="#logs-container" hx-swap="outerHTML"
            class="px-4 py-2 rounded-lg shadow-sm cursor-pointer bg-white hover:bg-slate-100 flex">
            <span class="material-symbols-outlined">
                keyboard_double_arrow_left
            </span>
        </button>

        <button hx-get="/logs?page={{prevPage}}" hx-target="#logs-container" hx-swap="outerHTML"
            class="px-4 py-2 rounded-lg shadow-sm cursor-pointer bg-white hover:bg-slate-100 flex">
            <span class="material-symbols-outlined">
                keyboard_arrow_left
            </span>
        </button>

        <button class="px-4 py-2 rounded-lg shadow-sm bg-blue-100 text-blue-600 font-semibold">
            {{page}}
        </button>

        <button hx-get="/logs?page={{nextPage}}" hx-target="#logs-container" hx-swap="outerHTML"
            class="px-4 py-2 rounded-lg shadow-sm cursor-pointer bg-white hover:bg-slate-100 flex">
            <span class="material-symbols-outlined">
                keyboard_arrow_right
            </span>
        </button>

        <button hx-get="/logs?page={{totalPages}}" hx-target="#logs-container" hx-swap="outerHTML"
            class="px-4 py-2 rounded-lg shadow-sm cursor-pointer bg-white hover:bg-slate-100 flex">
            <span class="material-symbols-outlined">
                keyboard_double_arrow_right
            </span>
        </button>

    </div>

    <p class="text-center text-sm text-gray-600 my-4">
        Showing page {{page}} of {{totalPages}}
    </p>

</div>