<title>{{title}}</title>

<div class="max-w-full mx-auto px-4">

    <!-- Header -->
    <div class="mt-3 sm:mt-8 flex items-start gap-4">
        <span
            class="material-symbols-outlined shrink-0 leading-none text-orange-700 bg-orange-100 dark:bg-orange-950 dark:text-orange-300 p-3 rounded-xl"
            style="font-size: 1.6rem;">
            account_circle
        </span>
        <div class="min-w-0">
            <p class="text-2xl sm:text-3xl font-semibold tracking-tight text-slate-900 dark:text-slate-100">Profile</p>
            <p class="text-sm sm:text-base text-slate-500 dark:text-slate-400 mt-0.5">Manage your account information
                and settings</p>
        </div>
    </div>

    <div class="flex flex-col gap-5 mt-6 pb-10">

        <!-- Identity card -->
        <div
            class="w-full bg-white dark:bg-gray-900 rounded-2xl border border-slate-200 dark:border-gray-800 overflow-hidden">

            <div class="p-5 sm:p-6">
                <div class="flex flex-col sm:flex-row sm:items-center gap-4">

                    <div
                        class="letter-box shrink-0 w-16 h-16 sm:w-20 sm:h-20 text-2xl sm:text-3xl flex justify-center items-center rounded-full bg-orange-100 ring-2 ring-orange-700/30 text-orange-700 dark:bg-orange-950 dark:ring-orange-500/40 dark:text-orange-200 capitalize font-semibold">
                        {{vm.firstName.[0]}}
                    </div>

                    <div class="min-w-0 flex-1">
                        <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
                            <p
                                class="full-name text-xl sm:text-2xl capitalize font-semibold text-slate-900 dark:text-slate-100 truncate">
                                {{vm.firstName}} {{vm.lastName}}
                            </p>

                            {{#if vm.verified}}
                            <span
                                class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full bg-green-100 dark:bg-green-950 text-green-700 dark:text-green-300 text-xs font-semibold">
                                <span class="h-1.5 w-1.5 bg-green-600 dark:bg-green-400 rounded-full"></span>
                                Verified
                            </span>
                            {{else}}
                            <span
                                class="inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full bg-red-100 dark:bg-red-950 text-red-700 dark:text-red-300 text-xs font-semibold">
                                <span class="h-1.5 w-1.5 bg-red-600 dark:bg-red-400 rounded-full"></span>
                                Not verified
                            </span>
                            {{/if}}
                        </div>

                        <p class="username text-slate-500 dark:text-slate-400 text-sm mt-0.5">@{{vm.username}}</p>
                    </div>
                </div>
            </div>

            <div class="h-px w-full bg-slate-100 dark:bg-gray-800"></div>

            <!-- Account meta: real responsive grid, not flex-wrap -->
            <div
                class="grid grid-cols-1 sm:grid-cols-3 divide-y sm:divide-y-0 sm:divide-x divide-slate-100 dark:divide-gray-800">
                <div class="email-container p-5 sm:p-6">
                    <p
                        class="email-heading text-xs uppercase tracking-wide text-slate-400 dark:text-slate-500 font-semibold">
                        Email address</p>
                    <p class="email mt-1 font-medium text-slate-900 dark:text-slate-100 truncate">{{vm.email}}</p>
                </div>
                <div class="role-container p-5 sm:p-6">
                    <p
                        class="role-heading text-xs uppercase tracking-wide text-slate-400 dark:text-slate-500 font-semibold">
                        Role</p>
                    <p class="role mt-1 font-medium text-slate-900 dark:text-slate-100 uppercase">{{vm.role}}</p>
                </div>
                <div class="uid-container p-5 sm:p-6">
                    <p
                        class="uid-heading text-xs uppercase tracking-wide text-slate-400 dark:text-slate-500 font-semibold">
                        User ID</p>
                    <p class="uid mt-1 font-mono text-sm text-slate-700 dark:text-slate-300 break-all">{{vm._id}}</p>
                </div>
            </div>
        </div>

        <!-- Danger zone -->
        <div
            class="w-full bg-red-50/60 dark:bg-red-950/20 rounded-2xl border border-red-200 dark:border-red-900/60 p-5 sm:p-6">

            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-red-700 dark:text-red-300"
                    style="font-size: 1.35rem;">warning</span>
                <p class="text-lg sm:text-xl font-semibold text-red-700 dark:text-red-300">Danger zone</p>
            </div>
            <p class="text-sm text-red-700/90 dark:text-red-300/90 mt-1.5">
                Deleting your account removes all of your data permanently. This can't be undone.
            </p>

            <div class="h-px w-full bg-red-200 dark:bg-red-900/60 my-5"></div>

            <div>
                <label for="deleteConfirmInputEmail"
                    class="block mb-2 text-xs uppercase tracking-wide text-red-700 dark:text-red-300 font-semibold">
                    Delete account
                </label>
                <input type="text" name="email" id="deleteConfirmInputEmail"
                    class="w-full bg-white dark:bg-gray-950 border border-slate-200 dark:border-red-900/60 rounded-lg px-3 py-2.5 text-sm text-slate-900 dark:text-slate-100 placeholder:text-slate-400 dark:placeholder:text-slate-500 focus:outline-none focus:ring-2 focus:ring-red-600/60 focus:border-red-600"
                    placeholder="Type &quot;{{vm.email}}&quot; to confirm" data-email="{{vm.email}}">

                <button type="button" id="deleteAccountBtn" hx-delete="/delete"
                    class="mt-4 w-full sm:w-auto inline-flex items-center justify-center gap-2 bg-red-700 hover:bg-red-800 active:bg-red-900 text-white text-sm font-medium disabled:opacity-50 disabled:cursor-not-allowed disabled:bg-slate-400 dark:disabled:bg-gray-700 px-4 py-2.5 rounded-lg transition-colors duration-150 cursor-pointer focus:outline-none focus:ring-2 focus:ring-red-600/60 focus:ring-offset-2 dark:focus:ring-offset-gray-950"
                    disabled>
                    <span class="material-symbols-outlined" style="font-size: 1.1rem;">delete_forever</span>
                    Delete my account
                </button>
            </div>
        </div>

    </div>
</div>