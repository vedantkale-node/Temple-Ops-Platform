<div class="w-full flex justify-center items-center h-dvh bg-gray-50 dark:bg-gray-950 px-4">
    <div
        class="relative flex flex-col w-full max-w-sm rounded-2xl bg-white dark:bg-gray-900 border border-slate-200 dark:border-gray-800 shadow-xl dark:shadow-gray-950/50 p-8">

        <!-- Logo / Branding -->
        <div class="flex flex-col items-center mb-6">
            <div class="flex items-center justify-center h-12 w-12 rounded-xl bg-slate-800 dark:bg-slate-100 mb-3">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white dark:text-slate-900"
                    viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                    stroke-linejoin="round">
                    <path d="M12 2 3 7v13h18V7l-9-5Z" />
                    <path d="M9 21V12h6v9" />
                </svg>
            </div>
            <h4 class="text-xl font-semibold text-slate-800 dark:text-slate-100">Temple Ops</h4>
            <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Sign in to manage your temple</p>
        </div>

        <form id="loginForm" class="w-full" action="/login" method="post">
            <div class="flex flex-col gap-5">
                <div class="w-full">
                    <label class="block mb-1.5 text-sm font-medium text-slate-600 dark:text-slate-300">Email</label>
                    <div class="relative">
                        <span
                            class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400 dark:text-slate-500">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect width="20" height="16" x="2" y="4" rx="2" />
                                <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
                            </svg>
                        </span>
                        <input type="email" name="email"
                            class="w-full bg-transparent placeholder:text-slate-400 dark:placeholder:text-slate-500 text-slate-700 dark:text-slate-100 text-sm border rounded-lg pl-9 pr-3 py-2.5 border-slate-300 dark:border-gray-700 dark:bg-gray-950 transition duration-200 focus:outline-none focus:ring-2 focus:ring-slate-800/20 dark:focus:ring-slate-500/30 focus:border-slate-500 hover:border-slate-400 dark:hover:border-slate-500"
                            placeholder="you@example.com" {{#if old}} value="{{old.email}}" {{/if}}
                            id="loginFieldEmail" />
                    </div>
                </div>

                <div class="w-full">
                    <label class="block mb-1.5 text-sm font-medium text-slate-600 dark:text-slate-300">Password</label>
                    <div class="relative">
                        <span
                            class="absolute inset-y-0 left-0 flex items-center pl-3 text-slate-400 dark:text-slate-500">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none"
                                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <rect width="18" height="11" x="3" y="11" rx="2" ry="2" />
                                <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                            </svg>
                        </span>
                        <input type="password" name="password"
                            class="w-full bg-transparent placeholder:text-slate-400 dark:placeholder:text-slate-500 text-slate-700 dark:text-slate-100 text-sm border border-slate-300 dark:border-gray-700 dark:bg-gray-950 rounded-lg pl-9 pr-16 py-2.5 transition duration-200 focus:outline-none focus:ring-2 focus:ring-slate-800/20 dark:focus:ring-slate-500/30 focus:border-slate-500 hover:border-slate-400 dark:hover:border-slate-500"
                            placeholder="••••••••" id="loginFieldPassword" />
                        <button id="showPasswordBtn" type="button"
                            class="text-xs font-medium absolute right-2 top-1/2 -translate-y-1/2 text-slate-600 dark:text-slate-300 cursor-pointer bg-slate-100 dark:bg-gray-800 hover:bg-slate-200 dark:hover:bg-gray-700 px-2.5 py-1 rounded-md transition-colors">show</button>
                    </div>
                </div>
            </div>

            <button id="loginBtnSubmit"
                class="mt-7 w-full rounded-lg bg-slate-800 dark:bg-slate-100 py-2.5 px-4 border border-transparent text-center text-sm font-medium text-white dark:text-slate-900 transition-all shadow-sm hover:shadow-md hover:bg-slate-700 dark:hover:bg-white focus:outline-none focus:ring-2 focus:ring-slate-800/30 dark:focus:ring-slate-100/30 active:bg-slate-700 dark:active:bg-white disabled:pointer-events-none disabled:opacity-50 cursor-pointer"
                type="submit">
                Sign In
            </button>

            <p class="mt-5 text-center text-sm text-slate-500 dark:text-slate-400">
                Don't have an account?
                <a href="/signup" class="font-medium text-slate-800 dark:text-slate-100 hover:underline">Sign up</a>
            </p>
        </form>
    </div>
</div>