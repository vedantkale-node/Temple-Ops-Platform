<!DOCTYPE html>
<html lang="en" class="h-full overflow-hidden bg-white dark:bg-gray-950">

{{> header}}

<body class="h-dvh overflow-hidden bg-white text-slate-900 dark:bg-gray-950 dark:text-slate-100"
    data-success="{{success}}" data-error="{{errors}}">
    <div class="flex h-full">
        {{> logoutModal}}

        <aside class="w-72 shrink-0 h-full p-3 bg-white dark:bg-gray-900">
            {{> sidebar}}
        </aside>

        <main class="flex-1 h-full overflow-y-auto bg-slate-50 text-slate-900 dark:bg-gray-950 dark:text-slate-100">
            <div id="main-content" class="w-full max-w-7xl mx-auto min-h-full px-6 py-6">
                {{{body}}}
            </div>
        </main>

    </div>
</body>
{{> scripts}}

</html>