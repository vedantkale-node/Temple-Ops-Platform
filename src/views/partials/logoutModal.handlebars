<div class="w-full h-dvh absolute z-10 justify-center items-center hidden" id="logoutModal">
    <div class="overlay absolute bg-black w-full h-dvh -z-10 opacity-40 dark:opacity-60" role="button"
        id="logoutModalClose"></div>

    <div
        class="relative w-full max-w-sm mx-4 rounded-2xl bg-white dark:bg-gray-900 border border-slate-200 dark:border-gray-800 shadow-xl dark:shadow-gray-950/50 p-6">

        <div class="flex flex-col items-center text-center">
            <div class="flex items-center justify-center h-14 w-14 rounded-full bg-red-100 dark:bg-red-950/50 mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"
                    class="w-7 h-7 text-red-600 dark:text-red-300">
                    <path fill-rule="evenodd"
                        d="M12 2.25a.75.75 0 01.75.75v9a.75.75 0 01-1.5 0V3a.75.75 0 01.75-.75zM6.166 5.106a.75.75 0 010 1.06 8.25 8.25 0 1011.668 0 .75.75 0 111.06-1.06c3.808 3.807 3.808 9.98 0 13.788-3.807 3.808-9.98 3.808-13.788 0-3.808-3.807-3.808-9.98 0-13.788a.75.75 0 011.06 0z"
                        clip-rule="evenodd"></path>
                </svg>
            </div>

            <h4 class="text-lg font-semibold text-slate-800 dark:text-slate-100">Log out?</h4>
            <p class="mt-1.5 text-sm text-slate-500 dark:text-slate-400">
                You'll need to sign in again to access the dashboard.
            </p>
        </div>

        <div class="mt-6 flex gap-3">
            <button type="button" onclick="document.getElementById('logoutModalClose').click()"
                class="flex-1 rounded-lg py-2.5 px-4 text-sm font-medium border border-slate-300 dark:border-gray-700 text-slate-700 dark:text-slate-200 bg-white dark:bg-gray-900 hover:bg-slate-50 dark:hover:bg-gray-800 transition-colors cursor-pointer">
                Cancel
            </button>
            <button role="button" hx-post="/logout" hx-swap="none"
                class="flex-1 rounded-lg py-2.5 px-4 text-sm font-medium bg-red-600 hover:bg-red-700 dark:bg-red-700 dark:hover:bg-red-600 text-white shadow-sm hover:shadow-md transition-all cursor-pointer">
                Log Out
            </button>
        </div>
    </div>
</div>